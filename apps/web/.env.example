
# =========================
# MindPocket 环境变量（线上部署优先）
# 在 Vercel -> Settings -> Environment Variables 中配置
# 参考 README_CN 的部署流程（Vercel + Neon + Blob + Upstash）
# =========================

# 1) 数据库（必填）
# 来源：Neon 集成后自动提供，或你自己的 PostgreSQL URL
DATABASE_URL=

# 2) 应用地址（必填）
# 线上示例: https://your-app.vercel.app
# 本地示例: http://127.0.0.1:3000
NEXT_PUBLIC_APP_URL=

# 3) 认证密钥（必填）
# 建议使用随机长字符串（>=32 位）
# 可用命令生成: openssl rand -base64 32
BETTER_AUTH_SECRET=

# 4) 文件存储（上传功能需要）
# 来源：Vercel Blob
BLOB_READ_WRITE_TOKEN=

# 5) 缓存/队列（可选，AI/缓存相关能力建议配置）
# 来源：Upstash Redis
KV_REST_API_READ_ONLY_TOKEN=
KV_REST_API_TOKEN=
KV_REST_API_URL=
KV_URL=
REDIS_URL=

# 6) 本地测试用（可选）
# 仅在本机做 Chromium 相关测试时需要
CHROMIUM_EXECUTABLE_PATH=
